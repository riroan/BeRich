# KIS API Credentials
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=12345678-01

# Mode: real or paper
KIS_PAPER_TRADING=true

# KIS HTS ID — required for WebSocket execution-notice subscriptions.
# Find it in KIS HTS/MTS login screen (보통 영문+숫자 5~12자). Without this,
# the bot can place orders but cannot detect fills in real time and
# falls back to a slower REST polling path only.
KIS_HTS_ID=your_hts_id_here

# MySQL Database
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=quant
MYSQL_USER=quant
MYSQL_PASSWORD=quant123

# Logging
LOG_LEVEL=INFO

# Discord Notifications (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# Dashboard Authentication (required - server will refuse to start if DASHBOARD_PASSWORD is not set)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=your_secure_password_here
